generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  IN
  OUT
}

model Role {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(50)
  users      User[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("roles")
}

model User {
  id                     Int                    @id @default(autoincrement())
  full_name              String                 @db.VarChar(150)
  email                  String                 @unique @db.VarChar(120)
  password_hash          String                 @db.VarChar(255)
  role_id                Int
  is_active              Boolean                @default(true)
  role                   Role                   @relation(fields: [role_id], references: [id])
  stock_receipts         StockReceipt[]         @relation("StockReceiptCreatedBy")
  stock_shipments        StockShipment[]        @relation("StockShipmentCreatedBy")
  inventory_transactions InventoryTransaction[] @relation("InventoryTransactionCreatedBy")
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(120)
  description String?   @db.VarChar(255)
  products    Product[]
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("categories")
}

model Supplier {
  id             Int            @id @default(autoincrement())
  name           String         @unique @db.VarChar(150)
  contact_person String?        @db.VarChar(120)
  phone          String?        @db.VarChar(50)
  email          String?        @db.VarChar(120)
  address        String?        @db.VarChar(255)
  products       Product[]
  stock_receipts StockReceipt[]
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  @@map("suppliers")
}

model Customer {
  id              Int             @id @default(autoincrement())
  name            String          @unique @db.VarChar(150)
  contact_person  String?         @db.VarChar(120)
  phone           String?         @db.VarChar(50)
  email           String?         @db.VarChar(120)
  address         String?         @db.VarChar(255)
  stock_shipments StockShipment[]
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  @@map("customers")
}

model Unit {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(100)
  short_name String    @unique @db.VarChar(20)
  products   Product[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("units")
}

model Product {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @db.VarChar(150)
  sku                    String                 @unique @db.VarChar(60)
  description            String?                @db.VarChar(255)
  category_id            Int
  supplier_id            Int
  unit_id                Int
  price                  Decimal                @db.Decimal(12, 2)
  quantity               Int                    @default(0)
  min_quantity           Int                    @default(0)
  category               Category               @relation(fields: [category_id], references: [id])
  supplier               Supplier               @relation(fields: [supplier_id], references: [id])
  unit                   Unit                   @relation(fields: [unit_id], references: [id])
  stock_receipt_items    StockReceiptItem[]
  stock_shipment_items   StockShipmentItem[]
  inventory_transactions InventoryTransaction[]
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt

  @@index([name])
  @@map("products")
}

model StockReceipt {
  id             Int                @id @default(autoincrement())
  receipt_number String             @unique @db.VarChar(50)
  supplier_id    Int
  created_by     Int
  receipt_date   DateTime
  status         String             @db.VarChar(30)
  total_amount   Decimal            @db.Decimal(14, 2)
  comment        String?            @db.VarChar(255)
  supplier       Supplier           @relation(fields: [supplier_id], references: [id])
  creator        User               @relation("StockReceiptCreatedBy", fields: [created_by], references: [id])
  items          StockReceiptItem[]
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  @@map("stock_receipts")
}

model StockReceiptItem {
  id         Int          @id @default(autoincrement())
  receipt_id Int
  product_id Int
  quantity   Int
  unit_price Decimal      @db.Decimal(12, 2)
  line_total Decimal      @db.Decimal(12, 2)
  receipt    StockReceipt @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  product    Product      @relation(fields: [product_id], references: [id])

  @@map("stock_receipt_items")
}

model StockShipment {
  id              Int                 @id @default(autoincrement())
  shipment_number String              @unique @db.VarChar(50)
  customer_id     Int
  created_by      Int
  shipment_date   DateTime
  status          String              @db.VarChar(30)
  total_amount    Decimal             @db.Decimal(14, 2)
  comment         String?             @db.VarChar(255)
  customer        Customer            @relation(fields: [customer_id], references: [id])
  creator         User                @relation("StockShipmentCreatedBy", fields: [created_by], references: [id])
  items           StockShipmentItem[]
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  @@map("stock_shipments")
}

model StockShipmentItem {
  id          Int           @id @default(autoincrement())
  shipment_id Int
  product_id  Int
  quantity    Int
  unit_price  Decimal       @db.Decimal(12, 2)
  line_total  Decimal       @db.Decimal(12, 2)
  shipment    StockShipment @relation(fields: [shipment_id], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [product_id], references: [id])

  @@map("stock_shipment_items")
}

model InventoryTransaction {
  id               Int             @id @default(autoincrement())
  product_id       Int
  transaction_type TransactionType
  quantity         Int
  reference_type   String          @db.VarChar(50)
  reference_id     Int
  created_by       Int
  transaction_date DateTime        @default(now())
  comment          String?         @db.VarChar(255)
  product          Product         @relation(fields: [product_id], references: [id])
  creator          User            @relation("InventoryTransactionCreatedBy", fields: [created_by], references: [id])

  @@index([product_id])
  @@map("inventory_transactions")
}